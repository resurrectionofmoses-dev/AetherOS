{
  "name": "aetheros",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --minify --sourcemap --outfile=dist/server.cjs && node scripts/obfuscate.js",
    "start": "node dist/server.cjs",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "hh:node": "hardhat node",
    "hh:compile": "hardhat compile",
    "hh:deploy": "hardhat run scripts/deploy.js --network localhost"
  },
  "dependencies": {
    "@google/genai": "^1.35.0",
    "@nomicfoundation/hardhat-toolbox": "^7.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "d3": "^7.9.0",
    "esbuild": "^0.28.0",
    "ethers": "^6.16.0",
    "express": "^5.2.1",
    "firebase": "^12.13.0",
    "hardhat": "^3.4.5",
    "jszip": "3.10.1",
    "katex": "0.16.9",
    "lucide-react": "^1.7.0",
    "motion": "^12.38.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-katex": "3.0.1",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "speakeasy": "^2.0.0",
    "tsx": "^4.22.2",
    "typescript": "~5.8.2",
    "uuid": "9.0.1",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/d3": "^7.4.3",
    "@types/node": "^22.14.0",
    "@types/qrcode": "^1.5.6",
    "@types/speakeasy": "^2.0.10",
    "javascript-obfuscator": "^5.4.7",
    "vitest": "^4.1.10"
  }
}
